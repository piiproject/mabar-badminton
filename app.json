{
  "expo": {
    "name": "Mabar Badminton Manager",
    "slug": "mabar-badminton-manager",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "splash": {
      "backgroundColor": "#22C55E"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#22C55E"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
